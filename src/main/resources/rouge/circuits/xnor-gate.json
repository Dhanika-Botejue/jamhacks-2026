        {"x":2,"y":1,"z":0,"block":"minecraft:redstone_wire"},
        {"x":2,"y":1,"z":2,"block":"minecraft:redstone_wire"},
        {"x":2,"y":1,"z":1,"block":"minecraft:redstone_wire"},
        {"x":3,"y":0,"z":1,"block":"minecraft:redstone_wall_torch[facing=east,lit=true]"},
        {"x":4,"y":1,"z":1,"block":"minecraft:redstone_wire"},
        {"x":3,"y":1,"z":1,"block":"minecraft:redstone_wire"}
      ]
    },
    {
      "title": "Final NOT (XOR inversion → XNOR) + lamp",
      "explanation": "NAND and OR both reach x=4,z=1. Both signals merge there (another OR of NAND and OR = NAND, since OR dominates). Torch at (5,0,1) inverts the merged XOR to produce XNOR. Lamp at (5,0,-1) lights when A==B.",
      "blocks": [
        {"x":0,"y":0,"z":0,"block":"minecraft:stone"},{"x":1,"y":0,"z":0,"block":"minecraft:stone"},{"x":2,"y":0,"z":0,"block":"minecraft:stone"},{"x":3,"y":0,"z":0,"block":"minecraft:stone"},{"x":4,"y":0,"z":0,"block":"minecraft:stone"},{"x":5,"y":0,"z":0,"block":"minecraft:stone"},
        {"x":0,"y":0,"z":1,"block":"minecraft:stone"},{"x":1,"y":0,"z":1,"block":"minecraft:stone"},{"x":2,"y":0,"z":1,"block":"minecraft:stone"},{"x":3,"y":0,"z":1,"block":"minecraft:stone"},{"x":4,"y":0,"z":1,"block":"minecraft:stone"},{"x":5,"y":0,"z":1,"block":"minecraft:stone"},
        {"x":0,"y":0,"z":2,"block":"minecraft:stone"},{"x":1,"y":0,"z":2,"block":"minecraft:stone"},{"x":2,"y":0,"z":2,"block":"minecraft:stone"},{"x":3,"y":0,"z":2,"block":"minecraft:stone"},{"x":4,"y":0,"z":2,"block":"minecraft:stone"},{"x":5,"y":0,"z":2,"block":"minecraft:stone"},
        {"x":0,"y":1,"z":0,"block":"minecraft:lever[face=floor,facing=south,powered=false]"},
        {"x":0,"y":1,"z":2,"block":"minecraft:lever[face=floor,facing=north,powered=false]"},
