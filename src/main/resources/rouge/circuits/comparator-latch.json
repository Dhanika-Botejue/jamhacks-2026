{
  "id": "comparator-latch",
  "title": "Comparator Latch",
  "category": "memory",
  "description": "Uses a comparator in subtraction mode to lock a signal. When the side input equals or exceeds the rear input the output goes to zero, latching state. Common in item-count detectors and container-full alarms.",
  "aliases": ["comparator memory", "comparator latch", "subtraction latch"],
  "inputs": ["signal", "side_input"],
  "outputs": ["output"],
  "footprint": "4x2x2",
  "steps": [
    {
      "title": "Foundation",
      "explanation": "4-wide, 2-deep stone base. Signal enters from the west; the comparator sits in the middle facing east; output goes east.",
