        {"x":0,"y":1,"z":0,"block":"minecraft:stone_button[face=floor,facing=south,powered=false]"},
        {"x":1,"y":1,"z":0,"block":"minecraft:repeater[delay=4,facing=east,locked=false,powered=false]"},
        {"x":2,"y":1,"z":0,"block":"minecraft:repeater[delay=4,facing=east,locked=false,powered=false]"},
