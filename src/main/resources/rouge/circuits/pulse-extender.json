{
  "id": "pulse-extender",
  "title": "Pulse Extender",
  "category": "timing",
  "description": "Stretches a short pulse into a longer one. A monostable or button click that would normally last 1-2 ticks is extended to several seconds using a repeater chain feeding back through a diode. Useful for holding pistons or lamps on for a controlled duration.",
  "aliases": ["pulse lengthener", "pulse stretcher", "signal extender"],
  "inputs": ["trigger"],
  "outputs": ["extended_pulse"],
  "footprint": "5x2x2",
  "steps": [
    {
      "title": "Foundation",
      "explanation": "5-wide, 2-deep stone base. Signal enters from the left (x=0) and travels east through the repeater loop.",
