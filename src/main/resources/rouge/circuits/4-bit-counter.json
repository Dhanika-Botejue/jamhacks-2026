{
  "id": "4-bit-counter",
  "title": "4-Bit Binary Counter",
  "category": "memory",
  "description": "Counts from 0 to 15 in binary using four T flip-flops chained together. Each flip-flop's Q output feeds the clock input of the next one, acting as a clock divider. The four lamp outputs display the binary number (bit 0 = LSB, bit 3 = MSB). Every button press increments the count by 1. Used in combination locks, sequencers, and timers.",
  "aliases": ["binary counter", "4 bit counter", "counter", "ripple counter"],
  "inputs": ["count_pulse"],
  "outputs": ["bit0", "bit1", "bit2", "bit3"],
  "footprint": "16x3x4",
